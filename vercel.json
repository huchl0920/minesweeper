{
  "rewrites": [
    {
      "source": "/api/twse/:path*",
      "destination": "https://mis.twse.com.tw/:path*"
    },
    {
      "source": "/api/moneydj/:path*",
      "destination": "https://www.moneydj.com/:path*"
    },
    {
      "source": "/api/twse_www/:path*",
      "destination": "https://www.twse.com.tw/:path*"
    },
    {
      "source": "/api/yahoo/:path*",
      "destination": "https://query2.finance.yahoo.com/:path*"
    },
    {
      "source": "/api/tpex/:path*",
      "destination": "https://www.tpex.org.tw/:path*"
    },
    {
      "source": "/api/finmind/:path*",
      "destination": "https://api.finmindtrade.com/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
