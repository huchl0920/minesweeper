{
  "rewrites": [
    {
      "source": "/api/twse/:path*",
      "destination": "https://mis.twse.com.tw/:path*"
    },
    {
      "source": "/api/yahoo/:path*",
      "destination": "https://query1.finance.yahoo.com/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
